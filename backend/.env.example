# --- LLM ---
# Google AI Studio API key for Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Data providers ---
# Tavily is used for both news and market/competitive research (https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Alpha Vantage is used for company fundamentals (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# --- Server ---
PORT=5001
CORS_ORIGIN=http://localhost:5173

# --- Cache ---
CACHE_TTL_MS=600000
